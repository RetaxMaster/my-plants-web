# Internal NestJS API base (server-only; never exposed to the browser).
# Production: point it at the API's localhost bind, e.g. http://127.0.0.1:5501
NUXT_API_BASE=http://localhost:8000
# Secret used by nuxt-auth-utils to seal the session cookie. Must be >=32 chars.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-at-least-32-chars

# ── Production process binding (Nitro reads these at runtime; unused by `nuxt dev`) ──
# The Nuxt SSR server binds here. In production it sits behind NGINX, bound to localhost only.
# HOST=127.0.0.1
# PORT=5500
# Public URL of the knowledge-chat engine's Socket.IO (admin chat). The BROWSER connects here
# directly (a WebSocket can't traverse the HTTP-only BFF proxy). Local dev defaults to the engine's
# localhost bind; production must be the public wss endpoint NGINX reverse-proxies to 127.0.0.1:3457.
# NUXT_PUBLIC_KNOWLEDGE_CHAT_SOCKET_URL=https://my-plants-wss.retaxmaster.com
